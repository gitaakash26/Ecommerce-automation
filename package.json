{
  "name": "playwright-ecommerce-automation",
  "version": "1.0.0",
  "description": "UI + API test automation suite for an e-commerce web app, built with Playwright and JavaScript using the Page Object Model.",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test tests/ui",
    "test:api": "npx playwright test tests/api",
    "test:chrome": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "report": "npx playwright show-report",
    "codegen": "npx playwright codegen https://www.saucedemo.com"
  },
  "keywords": [
    "playwright",
    "test-automation",
    "javascript",
    "e2e-testing",
    "page-object-model"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "dotenv": "^16.4.5"
  }
}
