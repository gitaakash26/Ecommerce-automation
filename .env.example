# Copy this file to .env and adjust as needed.
# The suite falls back to these defaults if no .env is present.

BASE_URL=https://www.saucedemo.com
STANDARD_USER=standard_user
LOCKED_USER=locked_out_user
PROBLEM_USER=problem_user
PASSWORD=secret_sauce

# reqres.in now requires an API key on every request (as of 2026).
# Get a free one at https://reqres.in/signup and paste it below.
REQRES_API_KEY=your_key_here
